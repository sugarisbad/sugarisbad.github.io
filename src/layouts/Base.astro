---
// Шрифты — self-hosted (Fontsource): без запросов к Google CDN на критическом пути.
import '@fontsource-variable/manrope';
import '@fontsource-variable/jetbrains-mono';
import '@fontsource-variable/space-grotesk';
import '../styles/global.css';
import { brand, contacts } from '../data/site';
import { t, localeUrl, type Locale } from '../i18n';

interface Props {
  title: string;
  description: string;
  locale?: Locale;
  /** Путь страницы без префикса локали: '' | 'cases/' | 'services/' | 'work/'. */
  path?: string;
  /** true — страница вне индекса (404 и т.п.): noindex, без canonical/hreflang. */
  noindex?: boolean;
}
const { title, description, locale = 'ru', path = '', noindex = false } = Astro.props;
const dict = t(locale);

const site = (Astro.site?.href ?? 'https://sugarisbad.github.io/').replace(/\/$/, '');
const urlRu = `${site}${localeUrl('ru', path)}`;
const urlEn = `${site}${localeUrl('en', path)}`;
const canonical = locale === 'ru' ? urlRu : urlEn;
const ogImage = `${site}/og.png`;

// Микроразметка: кто автор сайта и что это за сайт.
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: dict.seo.personName,
  alternateName: contacts.username,
  jobTitle: dict.seo.jobTitle,
  email: `mailto:${contacts.email}`,
  url: `${site}/`,
  sameAs: [contacts.githubUrl, contacts.telegramUrl],
  knowsAbout: ['DevOps', 'Linux', 'Docker', 'CI/CD', 'nginx', 'Monitoring', 'Self-hosted AI', 'Ollama'],
};
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: dict.seo.siteName,
  url: `${site}/`,
  inLanguage: [{ '@type': 'Language', name: 'Russian', alternateName: 'ru' }, { '@type': 'Language', name: 'English', alternateName: 'en' }],
};
// Бренд как организация: связывает страницы в единый сущностный граф
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: brand,
  description: dict.home.desc,
  url: `${site}/`,
  logo: ogImage,
  image: ogImage,
  email: `mailto:${contacts.email}`,
  founder: { '@type': 'Person', name: dict.seo.personName, jobTitle: dict.seo.jobTitle },
  sameAs: [contacts.githubUrl, contacts.telegramUrl],
  priceRange: locale === 'ru' ? '4 800 ₽ – 192 000 ₽' : '$55 – $2,200',
  areaServed: 'Worldwide',
};
// Хлебные крошки для подстраниц
const crumbNames: Record<string, string> = {
  'cases/': dict.nav.cases,
  'services/': dict.nav.services,
  'work/': dict.nav.work,
};
const breadcrumbLd =
  !noindex && path && crumbNames[path]
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: dict.nav.home, item: `${site}${localeUrl(locale, '')}` },
          { '@type': 'ListItem', position: 2, name: crumbNames[path], item: canonical },
        ],
      }
    : null;
---

<!doctype html>
<html lang={dict.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#07080c" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f5f7fc" />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <>
        <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
        <link rel="canonical" href={canonical} />
        <link rel="alternate" hreflang="ru" href={urlRu} />
        <link rel="alternate" hreflang="en" href={urlEn} />
        <link rel="alternate" hreflang="x-default" href={urlRu} />
      </>
    )}
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Подтверждение прав в поисковиках: вставьте коды из Яндекс.Вебмастера и
         Google Search Console (или подтверждайте через DNS/файл — см. README). -->
    <!-- <meta name="yandex-verification" content="XXXXXXXXXXXXXXXX" /> -->
    <!-- <meta name="google-site-verification" content="XXXXXXXXXXXXXXXX" /> -->

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={dict.seo.siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={dict.seo.ogImageAlt} />
    <meta property="og:locale" content={dict.ogLocale} />
    <meta property="og:locale:alternate" content={locale === 'ru' ? 'en_US' : 'ru_RU'} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Ccircle cx='16' cy='16' r='9' fill='%234ff0c7'/%3E%3C/svg%3E" />

    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    {breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}
    <slot name="head" />
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true"></div>
    <div class="bg-fx"></div>
    <div class="bg-grid"></div>
    <div class="bg-grain"></div>

    <slot />

    <!-- Ненавязчивая подсказка версии на языке браузера клиента -->
    <div class="lang-banner" id="lang-banner" hidden>
      <span id="lang-banner-text"></span>
      <a href="#" id="lang-banner-link"></a>
      <button id="lang-banner-close" aria-label="Close">✕</button>
    </div>

    <script>
      // мобильное меню
      const burger = document.getElementById('burger');
      const nav = document.getElementById('nav');
      burger?.addEventListener('click', () => nav?.classList.toggle('open'));
      nav?.querySelectorAll('a').forEach((a) =>
        a.addEventListener('click', () => nav?.classList.remove('open'))
      );

      // текущий год
      const y = document.getElementById('year');
      if (y) y.textContent = String(new Date().getFullYear());

      const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

      // заголовок hero собирается построчно: оборачиваем строки (разделитель — <br>)
      // в маски, сохраняя внутренние span'ы (.grad-text)
      if (!reducedMotion) {
        document.querySelectorAll('.hero h1').forEach((h) => {
          const groups: Node[][] = [[]];
          [...h.childNodes].forEach((n) => {
            if (n.nodeName === 'BR') groups.push([]);
            else groups[groups.length - 1].push(n);
          });
          if (!groups.some((g) => g.length)) return;
          h.textContent = '';
          groups.forEach((g, i) => {
            const line = document.createElement('span');
            line.className = 'h1-line';
            const inner = document.createElement('span');
            inner.className = 'h1-line-in';
            inner.style.setProperty('--i', String(i));
            g.forEach((n) => inner.appendChild(n));
            line.appendChild(inner);
            h.appendChild(line);
          });
        });
      }

      // «живой» терминал в hero: печатаем строки по очереди, один прогон
      const term = document.querySelector<HTMLElement>('.term[data-term-lines]');
      if (term && !reducedMotion) {
        const lines = [...term.querySelectorAll<HTMLElement>('.term-line')];
        const texts = lines.map((l) => l.textContent ?? '');
        lines.forEach((l) => {
          l.textContent = '';
          l.style.display = 'none';
        });
        let li = 0;
        const typeLine = () => {
          if (li >= lines.length) return;
          const el = lines[li];
          const txt = texts[li];
          const isCmd = txt.startsWith('$');
          el.style.display = 'block';
          let ci = 0;
          const iv = setInterval(() => {
            ci++;
            el.textContent = txt.slice(0, ci);
            if (ci >= txt.length) {
              clearInterval(iv);
              li++;
              setTimeout(typeLine, isCmd ? 240 : 420);
            }
          }, isCmd ? 30 : 9);
        };
        setTimeout(typeLine, 850);
      }

      // reveal с грид-контейнера переносим на карточки — так работает каскад
      document.querySelectorAll<HTMLElement>('.grid, .cases-grid, .price-grid, .steps').forEach((g) => {
        if (g.classList.contains('reveal')) {
          g.classList.remove('reveal');
          [...g.children].forEach((c) => c.classList.add('reveal'));
        }
        [...g.children].forEach((c, i) => {
          if (c instanceof HTMLElement && c.classList.contains('reveal'))
            c.style.transitionDelay = `${Math.min(i, 7) * 70}ms`;
        });
      });

      // появление секций при скролле
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              const el = e.target as HTMLElement;
              el.classList.add('in');
              io.unobserve(el);
              // transition-delay нужен только на входе — иначе тормозит hover
              if (el.style.transitionDelay)
                setTimeout(() => (el.style.transitionDelay = ''), 1300);
            }
          });
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      // подсветка + лёгкий 3D-наклон карточек за курсором
      // (геометрию читаем один раз на mouseenter, а не на каждый mousemove —
      // getBoundingClientRect в mousemove вызывает forced reflow)
      document.querySelectorAll<HTMLElement>('.card').forEach((card) => {
        let rect: DOMRect | null = null;
        card.addEventListener('mouseenter', () => {
          rect = card.getBoundingClientRect();
        });
        card.addEventListener('mousemove', (ev) => {
          if (!rect) rect = card.getBoundingClientRect();
          const x = ev.clientX - rect.left;
          const y = ev.clientY - rect.top;
          card.style.setProperty('--mx', `${x}px`);
          if (!reducedMotion) {
            card.style.setProperty('--ry', `${(x / rect.width - 0.5) * 5}deg`);
            card.style.setProperty('--rx', `${(0.5 - y / rect.height) * 5}deg`);
          }
        });
        card.addEventListener('mouseleave', () => {
          card.style.setProperty('--rx', '0deg');
          card.style.setProperty('--ry', '0deg');
        });
      });

      // прогресс прочтения + состояние шапки (только transform, без reflow)
      const headerEl = document.querySelector('header');
      let scrollRaf = 0;
      const onScroll = () => {
        scrollRaf = 0;
        const max = document.documentElement.scrollHeight - innerHeight;
        document.documentElement.style.setProperty('--sp', String(max > 0 ? Math.min(scrollY / max, 1) : 0));
        headerEl?.classList.toggle('scrolled', scrollY > 8);
      };
      addEventListener('scroll', () => {
        if (!scrollRaf) scrollRaf = requestAnimationFrame(onScroll);
      }, { passive: true });
      onScroll();

      // цифры статистики «расшифровываются» при появлении
      if (!reducedMotion) {
        const scramble = (el: HTMLElement) => {
          const final = el.textContent ?? '';
          const chars = '<>/\\[]{}=+*#0123456789';
          const total = Math.max(16, final.length * 5);
          let frame = 0;
          const tick = () => {
            frame++;
            const done = Math.floor((frame / total) * final.length);
            el.textContent =
              final.slice(0, done) +
              [...final.slice(done)].map((c) => (c === ' ' ? ' ' : chars[(Math.random() * chars.length) | 0])).join('');
            if (done < final.length) requestAnimationFrame(tick);
            else el.textContent = final;
          };
          tick();
        };
        const statIo = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                statIo.unobserve(e.target);
                setTimeout(() => scramble(e.target as HTMLElement), 350);
              }
            });
          },
          { threshold: 0.4 }
        );
        document.querySelectorAll<HTMLElement>('.stat b, .case-stat b').forEach((el) => statIo.observe(el));
      }

      // мягкий свет за курсором — только на устройствах с мышью
      if (!reducedMotion && matchMedia('(pointer: fine)').matches) {
        const glow = document.createElement('div');
        glow.className = 'bg-cursor';
        document.body.appendChild(glow);
        let tx = 0, ty = 0, gx = 0, gy = 0, glowRaf = 0;
        const follow = () => {
          gx += (tx - gx) * 0.12;
          gy += (ty - gy) * 0.12;
          glow.style.transform = `translate(${gx - 280}px, ${gy - 280}px)`;
          glowRaf = Math.abs(tx - gx) + Math.abs(ty - gy) > 0.5 ? requestAnimationFrame(follow) : 0;
        };
        addEventListener('pointermove', (e) => {
          tx = e.clientX;
          ty = e.clientY;
          glow.style.opacity = '1';
          if (!glowRaf) glowRaf = requestAnimationFrame(follow);
        }, { passive: true });
      }

      // Выбор языка: клик по переключателю запоминаем; посетителю с другим
      // языком браузера один раз показываем подсказку (без авторедиректа —
      // он вредит и поисковым роботам, и людям).
      const LS = 'site-lang';
      document.querySelectorAll<HTMLAnchorElement>('.lang-switch a').forEach((a) =>
        a.addEventListener('click', () => localStorage.setItem(LS, a.dataset.lang ?? ''))
      );
      try {
        const here = location.pathname === '/en' || location.pathname.startsWith('/en/') ? 'en' : 'ru';
        const saved = localStorage.getItem(LS);
        // ?lang-hint — принудительный показ плашки (для проверки вёрстки)
        const force = new URLSearchParams(location.search).has('lang-hint');
        let wants = saved || ((navigator.language || '').toLowerCase().startsWith('ru') ? 'ru' : 'en');
        if (force) wants = here === 'ru' ? 'en' : 'ru';
        if (wants !== here && (force || !sessionStorage.getItem('lang-hint'))) {
          const other =
            here === 'ru'
              ? '/en' + (location.pathname === '/' ? '/' : location.pathname)
              : location.pathname.replace(/^\/en\/?/, '/');
          const banner = document.getElementById('lang-banner')!;
          const text = document.getElementById('lang-banner-text')!;
          const link = document.getElementById('lang-banner-link') as HTMLAnchorElement;
          text.textContent = wants === 'en' ? 'This page is also available in English.' : 'Эта страница есть и на русском.';
          link.textContent = wants === 'en' ? 'Switch to English →' : 'Открыть на русском →';
          link.href = other;
          link.addEventListener('click', () => localStorage.setItem(LS, wants));
          banner.hidden = false;
          banner.classList.add('show');
          document.getElementById('lang-banner-close')?.addEventListener('click', () => {
            banner.classList.remove('show');
            banner.hidden = true;
            sessionStorage.setItem('lang-hint', '1');
          });
        }
      } catch {}
    </script>
  </body>
</html>
