---
// Шрифты — self-hosted (Fontsource): без запросов к Google CDN на критическом пути.
import '@fontsource-variable/manrope';
import '@fontsource-variable/jetbrains-mono';
import '@fontsource-variable/space-grotesk';
import '../styles/global.css';
import { brand, contacts } from '../data/site';
import { t, localeUrl, type Locale } from '../i18n';

interface Props {
  title: string;
  description: string;
  locale?: Locale;
  /** Путь страницы без префикса локали: '' | 'cases/' | 'services/' | 'work/'. */
  path?: string;
  /** true — страница вне индекса (404 и т.п.): noindex, без canonical/hreflang. */
  noindex?: boolean;
  /** Вариант фоновой анимации: home — 3 линии + пятно, services — 1 линия, page — 2 линии. */
  bg?: 'home' | 'page' | 'services';
}
const { title, description, locale = 'ru', path = '', noindex = false, bg = 'page' } = Astro.props;
const dict = t(locale);

const site = (Astro.site?.href ?? 'https://opsmith.ru/').replace(/\/$/, '');
const urlRu = `${site}${localeUrl('ru', path)}`;
const urlEn = `${site}${localeUrl('en', path)}`;
const canonical = locale === 'ru' ? urlRu : urlEn;
const ogImage = `${site}/og.jpg`;

// Микроразметка: кто автор сайта и что это за сайт.
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: dict.seo.personName,
  alternateName: contacts.username,
  jobTitle: dict.seo.jobTitle,
  email: `mailto:${contacts.email}`,
  url: `${site}/`,
  knowsAbout: ['DevOps', 'Linux', 'Docker', 'Kubernetes', 'CI/CD', 'nginx', 'Monitoring', 'Self-hosted AI', 'Ollama'],
};
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: dict.seo.siteName,
  url: `${site}/`,
  inLanguage: [{ '@type': 'Language', name: 'Russian', alternateName: 'ru' }, { '@type': 'Language', name: 'English', alternateName: 'en' }],
};
// Бренд как организация: связывает страницы в единый сущностный граф
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: brand,
  description: dict.home.desc,
  url: `${site}/`,
  logo: ogImage,
  image: ogImage,
  email: `mailto:${contacts.email}`,
  founder: { '@type': 'Person', name: dict.seo.personName, jobTitle: dict.seo.jobTitle },
  priceRange: locale === 'ru' ? '3 600 ₽ – 192 000 ₽' : '$40 – $2,100',
  areaServed: 'Worldwide',
};
// Хлебные крошки для подстраниц
const crumbNames: Record<string, string> = {
  'cases/': dict.nav.cases,
  'services/': dict.nav.services,
  'work/': dict.nav.work,
};
const breadcrumbLd =
  !noindex && path && crumbNames[path]
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: dict.nav.home, item: `${site}${localeUrl(locale, '')}` },
          { '@type': 'ListItem', position: 2, name: crumbNames[path], item: canonical },
        ],
      }
    : null;
---

<!doctype html>
<html lang={dict.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0b0b0d" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f5f2ea" />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <>
        <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
        <link rel="canonical" href={canonical} />
        <link rel="alternate" hreflang="ru" href={urlRu} />
        <link rel="alternate" hreflang="en" href={urlEn} />
        <link rel="alternate" hreflang="x-default" href={urlRu} />
      </>
    )}
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Подтверждение прав в поисковиках (дублирует DNS TXT-записи) -->
    <meta name="yandex-verification" content="915cbe8fccc35863" />
    <meta name="google-site-verification" content="6aBHVruKpFLw0bY4eI_yQXoe3fEzUv3gnknT7Rs3Rw8" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={dict.seo.siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={dict.seo.ogImageAlt} />
    <meta property="og:locale" content={dict.ogLocale} />
    <meta property="og:locale:alternate" content={locale === 'ru' ? 'en_US' : 'ru_RU'} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect x='7' y='7' width='18' height='18' fill='%23d8c9a3'/%3E%3C/svg%3E" />

    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    {breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}

    <!-- Yandex.Metrika counter: загрузка отложена до load+idle, чтобы 89 KiB
         tag.js и вебвизор не конкурировали с контентом за сеть и CPU -->
    <script is:inline type="text/javascript">
      (function () {
        function initMetrika() {
          (function(m,e,t,r,i,k,a){
              m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
              m[i].l=1*new Date();
              for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
              k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
          })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=110731753', 'ym');

          ym(110731753, 'init', {ssr:true, webvisor:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true});
        }
        function whenIdle() {
          if ('requestIdleCallback' in window) requestIdleCallback(initMetrika, { timeout: 3000 });
          else setTimeout(initMetrika, 1500);
        }
        if (document.readyState === 'complete') whenIdle();
        else window.addEventListener('load', whenIdle);
      })();
    </script>
    <noscript><div><img src="https://mc.yandex.ru/watch/110731753" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    <!-- /Yandex.Metrika counter -->

    <slot name="head" />
  </head>
  <body>
    <!-- Фоновая анимация: кривые Безье + вертикальные волосяные линии -->
    <div class="bg" aria-hidden="true">
      <svg viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice">
        <path
          d="M -60 620 C 330 570 560 680 930 600 S 1400 500 1560 550"
          fill="none"
          stroke="var(--accent)"
          stroke-width="1"
          opacity={bg === 'home' ? '.3' : bg === 'services' ? '.22' : '.26'}
          stroke-dasharray="800"
          style="animation:lineflow 12s linear infinite"
        />
        {bg === 'home' && (
          <path
            d="M -60 680 C 400 640 660 730 1010 660 S 1420 570 1560 610"
            fill="none"
            stroke="var(--muted)"
            stroke-width="1"
            opacity=".18"
            stroke-dasharray="800"
            style="animation:lineflow 16s linear infinite"
          />
        )}
        {bg !== 'services' && (
          <path
            d="M -60 200 C 360 240 640 150 980 210 S 1420 290 1560 250"
            fill="none"
            stroke="var(--muted)"
            stroke-width="1"
            opacity=".12"
            stroke-dasharray="800"
            style="animation:lineflow 20s linear infinite"
          />
        )}
        {bg === 'home' && (
          <>
            <circle cx="930" cy="600" r="3" fill="var(--accent)" opacity=".85" />
            <circle cx="560" cy="655" r="2.5" fill="var(--accent)" opacity=".45" />
            <circle cx="980" cy="210" r="2.5" fill="var(--accent)" opacity=".4" />
          </>
        )}
      </svg>
      <div class="bg-cols"></div>
      {bg === 'home' && <div class="bg-spot"></div>}
    </div>

    <div class="page">
      <slot />
    </div>

    <!-- Ненавязчивая подсказка версии на языке браузера клиента -->
    <div class="lang-banner" id="lang-banner" hidden>
      <span id="lang-banner-text"></span>
      <a href="#" id="lang-banner-link"></a>
      <button id="lang-banner-close" aria-label="Close">✕</button>
    </div>

    <script>
      // Выбор языка: клик по переключателю запоминаем; посетителю с другим
      // языком браузера один раз показываем подсказку (без авторедиректа —
      // он вредит и поисковым роботам, и людям).
      const LS = 'site-lang';
      document.querySelectorAll<HTMLAnchorElement>('.lang-switch a').forEach((a) =>
        a.addEventListener('click', () => localStorage.setItem(LS, a.dataset.lang ?? ''))
      );
      try {
        const here = location.pathname === '/en' || location.pathname.startsWith('/en/') ? 'en' : 'ru';
        const saved = localStorage.getItem(LS);
        // ?lang-hint — принудительный показ плашки (для проверки вёрстки)
        const force = new URLSearchParams(location.search).has('lang-hint');
        let wants = saved || ((navigator.language || '').toLowerCase().startsWith('ru') ? 'ru' : 'en');
        if (force) wants = here === 'ru' ? 'en' : 'ru';
        if (wants !== here && (force || !sessionStorage.getItem('lang-hint'))) {
          const other =
            here === 'ru'
              ? '/en' + (location.pathname === '/' ? '/' : location.pathname)
              : location.pathname.replace(/^\/en\/?/, '/');
          const banner = document.getElementById('lang-banner')!;
          const text = document.getElementById('lang-banner-text')!;
          const link = document.getElementById('lang-banner-link') as HTMLAnchorElement;
          text.textContent = wants === 'en' ? 'This page is also available in English.' : 'Эта страница есть и на русском.';
          link.textContent = wants === 'en' ? 'Switch to English →' : 'Открыть на русском →';
          link.href = other;
          link.addEventListener('click', () => localStorage.setItem(LS, wants));
          banner.hidden = false;
          banner.classList.add('show');
          document.getElementById('lang-banner-close')?.addEventListener('click', () => {
            banner.classList.remove('show');
            banner.hidden = true;
            sessionStorage.setItem('lang-hint', '1');
          });
        }
      } catch {}
    </script>
  </body>
</html>
