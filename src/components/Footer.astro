---
import { brand, contacts } from '../data/site';
import { localeUrl, type Locale } from '../i18n';
import { t } from '../i18n';
import LogoMark from './LogoMark.astro';

interface Props {
  locale?: Locale;
  /** true — без верхнего отступа (страница услуг: секция сама даёт паддинг). */
  flush?: boolean;
}
const { locale = 'ru', flush = false } = Astro.props;
const dict = t(locale);
const base = import.meta.env.BASE_URL;
---

<footer class={flush ? 'flush' : undefined}>
  <div class="wrap foot">
    <a class="brand" href={localeUrl(locale, '', base)}><LogoMark size={17} />{brand}</a>
    <span class="foot-links">
      <a href={`mailto:${contacts.email}`}>{contacts.email}</a>
      <a href={locale === 'ru' ? '/rss.xml' : '/en/rss.xml'}>RSS</a>
    </span>
    <span class="tag">{dict.footer.tagline}</span>
  </div>
</footer>
