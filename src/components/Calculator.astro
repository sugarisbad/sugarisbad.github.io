---
// Калькулятор заказа: чекбоксы по прайсу → стартовая сумма → deep-link в бота.
// Выбор кодируется однобуквенными кодами в payload /start:
// t.me/<bot>?start=calc-<коды> — бот расшифрует и приложит состав заказа к заявке.
// RU — рубли из pricing.ts; EN — доллары по курсу ЦБ (fetch на клиенте,
// fallback FALLBACK_USD_RATE), округление вверх до $5, минимум $5.
import { contacts } from '../data/site';
import { PRICING, BUNDLES, PACKAGES, FALLBACK_USD_RATE, CBR_RATE_URL } from '../data/pricing';
import { t, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}
const { locale = 'ru' } = Astro.props;
const dict = t(locale);
const calc = dict.servicesPage.calc;

const usd = (rub: number, rate: number) => Math.max(5, Math.ceil(rub / rate / 5) * 5);
const priceLabel = (it: (typeof PRICING)[number]['items'][number]) => {
  const from = it.from ? calc.fromPrefix : '';
  const suffix = it.monthly ? calc.monthlySuffix : it.hourly ? calc.hourlySuffix : '';
  const amount =
    locale === 'ru'
      ? `${it.rub.toLocaleString('ru-RU')} ₽`
      : `$${usd(it.rub, FALLBACK_USD_RATE).toLocaleString('en-US')}`;
  return `${from}${amount}${suffix}`;
};

// Слаги связок → строки кодов: скрипту достаточно сверить коды заказа.
const itemBySlug = new Map(PRICING.flatMap((g) => g.items.map((it) => [it.slug, it])));
const codeBySlug = (s: string) => itemBySlug.get(s)?.code ?? '';
const bundles = BUNDLES.map((b) => ({ codes: b.req.map(codeBySlug).join(''), save: b.save }));

// Готовые пакеты: набор кодов + суммы (сумма позиций, скидка внутри набора, итог).
// EN считается так же, как итог в панели: usd() по каждой позиции, скидка — round.
// Клиент на EN перерисует по живому курсу (repaintPackages).
const packages = PACKAGES.map((p) => {
  const codes = p.items.map(codeBySlug).join('');
  const items = p.items.map((s) => itemBySlug.get(s)!);
  const inPkg = (b: (typeof BUNDLES)[number]) =>
    [...b.req.map(codeBySlug).join('')].every((c) => codes.includes(c));
  const sum =
    locale === 'ru'
      ? items.reduce((acc, it) => acc + it.rub, 0)
      : items.reduce((acc, it) => acc + usd(it.rub, FALLBACK_USD_RATE), 0);
  const save = BUNDLES.reduce(
    (acc, b) => acc + (inPkg(b) ? (locale === 'ru' ? b.save : Math.round(b.save / FALLBACK_USD_RATE)) : 0),
    0
  );
  return { ...p, codes, sum, final: sum - save };
});
const pkgPrice = (n: number) =>
  locale === 'ru' ? `${n.toLocaleString('ru-RU')} ₽` : `$${n.toLocaleString('en-US')}`;

// Метка «своя задача»: custom / custom-en
const customLink = `${contacts.botUrl}?start=custom${locale === 'en' ? '-en' : ''}`;
---

<section class="calc-wrap" id="calc">
  <div class="wrap">
    <div class="calc-group-title pkg-title">{dict.servicesPage.packagesKicker}</div>
    <div class="pkg-grid">
      {packages.map((p) => (
        <button class="pkg" data-codes={p.codes} type="button">
          <span class="pkg-name">{locale === 'ru' ? p.name_ru : p.name_en}</span>
          <span class="pkg-desc">{locale === 'ru' ? p.desc_ru : p.desc_en}</span>
          <span class="pkg-items">
            {p.items.map((s) => (
              <span>✓ {locale === 'ru' ? itemBySlug.get(s)?.name_ru : itemBySlug.get(s)?.name_en}</span>
            ))}
          </span>
          <span class="pkg-price-row">
            <s class="pkg-price-old">{pkgPrice(p.sum)}</s>
            <b class="pkg-price-new">{calc.fromPrefix}{pkgPrice(p.final)}</b>
          </span>
          <span class="pkg-btn" data-select={dict.servicesPage.pkgSelect} data-selected={dict.servicesPage.pkgSelected}>{dict.servicesPage.pkgSelect}</span>
        </button>
      ))}
    </div>
  </div>
  <div class="wrap calc-grid">
    <div>
      {PRICING.map((g) => (
        <div class="calc-group">
          <div class="calc-group-title">{locale === 'ru' ? g.title_ru : g.title_en}</div>
          {g.items.map((it) => (
            <label class="calc-item">
              <input
                type="checkbox"
                data-code={it.code}
                data-rub={it.rub}
                data-monthly={it.monthly ? '1' : undefined}
              />
              <span class="calc-box" aria-hidden="true"></span>
              <span class="calc-name">
                {locale === 'ru' ? it.name_ru : it.name_en}
                <em>{locale === 'ru' ? it.time_ru : it.time_en}</em>
              </span>
              <span
                class="calc-price"
                data-rub={it.rub}
                data-from={it.from ? '1' : undefined}
                data-suffix={it.monthly ? calc.monthlySuffix : it.hourly ? calc.hourlySuffix : ''}
              >{priceLabel(it)}</span>
            </label>
          ))}
        </div>
      ))}
      <div class="calc-custom">
        <div>
          <b>{dict.servicesPage.custom.title}</b>
          <p>{dict.servicesPage.custom.text}</p>
        </div>
        <a href={customLink} class="btn-ghost btn">{dict.servicesPage.custom.btn}</a>
      </div>
    </div>

    <aside
      class="calc-summary"
      data-locale={locale}
      data-bot={contacts.botUrl}
      data-bundles={JSON.stringify(bundles)}
      data-fallback-rate={FALLBACK_USD_RATE}
      data-rate-url={CBR_RATE_URL}
      data-from-prefix={calc.fromPrefix}
      data-monthly-suffix={calc.monthlySuffix}
    >
      <div class="calc-count">{calc.countLabel} <b id="calc-count">0</b></div>
      <div class="calc-line" id="calc-items" hidden>
        <span>{calc.itemsSumLabel}</span>
        <b id="calc-items-sum">—</b>
      </div>
      <div class="calc-line combo" id="calc-combo" hidden>
        <span>{calc.comboLabel}</span>
        <b id="calc-combo-sum">—</b>
      </div>
      <div class="calc-total">
        <span>{calc.totalLabel}</span>
        <b id="calc-total">—</b>
      </div>
      <div class="calc-line monthly" id="calc-monthly" hidden>
        <span>{calc.monthlyLabel}</span>
        <b id="calc-monthly-sum">—</b>
      </div>
      <a
        class="calc-send"
        id="calc-send"
        aria-disabled="true"
        data-send={calc.btnSend}
        data-empty={calc.btnEmpty}
      >{calc.btnEmpty}</a>
      <a href={contacts.calendlyUrl} class="calc-call">{calc.btnCall}</a>
      <p class="calc-note"><span>{calc.note}</span> <span id="calc-rate-footnote" hidden>{dict.servicesPage.rateNoteFallback}</span></p>
    </aside>
  </div>
</section>

<script>
  const root = document.getElementById('calc');
  if (root) {
    const summary = root.querySelector<HTMLElement>('.calc-summary')!;
    const locale = summary.dataset.locale ?? 'ru';
    const botUrl = summary.dataset.bot ?? '';
    const bundles: { codes: string; save: number }[] = JSON.parse(summary.dataset.bundles ?? '[]');
    const fromPrefix = summary.dataset.fromPrefix ?? '';
    const monthlySuffix = summary.dataset.monthlySuffix ?? '';
    let rate = Number(summary.dataset.fallbackRate) || 92;

    const boxes = [...root.querySelectorAll<HTMLInputElement>('input[type=checkbox]')];
    const countEl = document.getElementById('calc-count')!;
    const itemsRow = document.getElementById('calc-items')!;
    const itemsEl = document.getElementById('calc-items-sum')!;
    const totalEl = document.getElementById('calc-total')!;
    const monthlyRow = document.getElementById('calc-monthly')!;
    const monthlyEl = document.getElementById('calc-monthly-sum')!;
    const comboRow = document.getElementById('calc-combo')!;
    const comboEl = document.getElementById('calc-combo-sum')!;
    const btn = document.getElementById('calc-send') as HTMLAnchorElement;
    const pkgs = [...root.querySelectorAll<HTMLButtonElement>('.pkg')];
    const boxByCode = new Map(boxes.map((b) => [b.dataset.code ?? '', b]));

    // округление вверх до $5, минимум $5 — как в референсе
    const usd = (rub: number) => Math.max(5, Math.ceil(rub / rate / 5) * 5);
    const fmtRub = (n: number) => `${n.toLocaleString('ru-RU')} ₽`;
    const fmtUsd = (n: number) => `$${n.toLocaleString('en-US')}`;

    const update = () => {
      let total = 0;
      let monthly = 0;
      let codes = '';
      let count = 0;
      boxes.forEach((b) => {
        if (!b.checked) return;
        count++;
        codes += b.dataset.code ?? '';
        const rub = Number(b.dataset.rub) || 0;
        const p = locale === 'ru' ? rub : usd(rub);
        if (b.dataset.monthly) monthly += p;
        else total += p;
      });
      // комбо-скидки: за каждую полностью собранную связку, суммируются
      let combo = 0;
      bundles.forEach((bl) => {
        if ([...bl.codes].every((c) => codes.includes(c)))
          combo += locale === 'ru' ? bl.save : Math.round(bl.save / rate);
      });
      // экономика на виду: сумма позиций → −скидка → итого (не выше суммы позиций)
      const itemsSum = total;
      total = Math.max(itemsSum - combo, 0);

      const fmt = locale === 'ru' ? fmtRub : fmtUsd;
      countEl.textContent = String(count);
      itemsRow.hidden = combo === 0 || itemsSum === 0;
      itemsEl.textContent = fmt(itemsSum);
      // без fromPrefix: подпись строки уже говорит «ИТОГО, ОТ»
      totalEl.textContent = count ? fmt(total) : '—';
      monthlyRow.hidden = monthly === 0;
      monthlyEl.textContent = `${fromPrefix}${fmt(monthly)}${monthlySuffix}`;
      comboRow.hidden = combo === 0;
      comboEl.textContent = `−${fmt(combo)}`;
      // подсветка карточек пакетов: активна, когда весь её состав отмечен
      pkgs.forEach((pk) => {
        const active = [...(pk.dataset.codes ?? '')].every((c) => boxByCode.get(c)?.checked);
        pk.classList.toggle('active', active);
        const label = pk.querySelector<HTMLElement>('.pkg-btn')!;
        label.textContent = (active ? label.dataset.selected : label.dataset.select) ?? '';
      });
      if (count && botUrl) {
        btn.href = `${botUrl}?start=calc-${codes}`;
        btn.removeAttribute('aria-disabled');
        btn.textContent = btn.dataset.send ?? '';
      } else {
        btn.removeAttribute('href');
        btn.setAttribute('aria-disabled', 'true');
        btn.textContent = btn.dataset.empty ?? '';
      }
    };

    boxes.forEach((b) => b.addEventListener('change', update));

    // Пакет: клик отмечает весь состав; повторный клик по выбранному — снимает
    pkgs.forEach((pk) =>
      pk.addEventListener('click', () => {
        const codes = [...(pk.dataset.codes ?? '')];
        const allChecked = codes.every((c) => boxByCode.get(c)?.checked);
        codes.forEach((c) => {
          const box = boxByCode.get(c);
          if (box) box.checked = !allChecked;
        });
        update();
      })
    );
    update();

    // EN: живой курс ЦБ → пересчёт цен позиций и итога, примечание под hero
    if (locale === 'en') {
      const repaintPrices = () => {
        root.querySelectorAll<HTMLElement>('.calc-price').forEach((el) => {
          const rub = Number(el.dataset.rub) || 0;
          el.textContent = `${el.dataset.from ? fromPrefix : ''}${fmtUsd(usd(rub))}${el.dataset.suffix ?? ''}`;
        });
      };
      // цены пакетов — той же арифметикой, что и панель итога
      const repaintPackages = () => {
        pkgs.forEach((pk) => {
          const codes = [...(pk.dataset.codes ?? '')];
          const sum = codes.reduce((acc, c) => acc + usd(Number(boxByCode.get(c)?.dataset.rub) || 0), 0);
          const save = bundles.reduce(
            (acc, bl) => acc + ([...bl.codes].every((c) => codes.includes(c)) ? Math.round(bl.save / rate) : 0),
            0
          );
          pk.querySelector<HTMLElement>('.pkg-price-old')!.textContent = fmtUsd(sum);
          pk.querySelector<HTMLElement>('.pkg-price-new')!.textContent = `${fromPrefix}${fmtUsd(Math.max(sum - save, 0))}`;
        });
      };
      fetch(summary.dataset.rateUrl ?? '')
        .then((r) => r.json())
        .then((d) => {
          const v = d?.Valute?.USD?.Value;
          if (!v) throw new Error('no rate');
          rate = v;
          repaintPrices();
          repaintPackages();
          update();
          const note = document.getElementById('rate-note');
          if (note) note.textContent = `${note.dataset.text} · today $1 = ${v.toFixed(2)} ₽`;
        })
        .catch(() => {
          const foot = document.getElementById('calc-rate-footnote');
          if (foot) foot.hidden = false;
        });
    }
  }
</script>
