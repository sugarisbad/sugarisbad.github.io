---
import { contacts } from '../data/site';
import { t, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
  title?: string;
  text?: string;
  source?: string; // payload deep-link: бот покажет, с какой страницы пришли
}
const { locale = 'ru', source = 'src-home' } = Astro.props;
const dict = t(locale);
const title = Astro.props.title ?? dict.contact.title;
const text = Astro.props.text ?? dict.contact.text;

const mailto = `mailto:${contacts.email}?subject=${encodeURIComponent(dict.contact.mailSubject)}`;
// суффикс -en в payload: бот видит и страницу, и язык клиента
const botLink = contacts.botUrl ? `${contacts.botUrl}?start=${source}${locale === 'en' ? '-en' : ''}` : '';
---

<section id="contact">
  <div class="wrap">
    <div class="cta-band reveal">
      <h2>{title}</h2>
      <p>{text}</p>
      <div class="hero-cta">
        {botLink && <a href={botLink} class="btn btn-primary">{dict.contact.btnBot}</a>}
        <a href={contacts.telegramUrl} class={`btn ${contacts.botUrl ? 'btn-ghost' : 'btn-primary'}`}>✈ Telegram · @{contacts.telegram}</a>
        <a href={contacts.phoneUrl} class="btn btn-ghost">📞 {contacts.phone}</a>
        <a href={mailto} class="btn btn-ghost">{dict.contact.btnMail}</a>
      </div>
    </div>
  </div>
</section>
