---
// Контактная секция главной: бот (primary) + Calendly + почта.
import { contacts } from '../data/site';
import { t, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
  /** Метка источника в payload deep-link'а — бот видит, с какой страницы пришли. */
  source?: string;
}
const { locale = 'ru', source = 'src-home' } = Astro.props;
const dict = t(locale);

// суффикс -en в payload: бот видит и страницу, и язык клиента
const botLink = `${contacts.botUrl}?start=${source}${locale === 'en' ? '-en' : ''}`;
---

<section id="contact" class="contact-sec">
  <div class="wrap">
    <span class="kicker">{dict.contact.kicker}</span>
    <h2 set:html={dict.contact.h2} />
    <p class="lead">{dict.contact.text}</p>
    <div class="cta-row">
      <a href={botLink} class="btn btn-primary">{dict.contact.btnBot}</a>
      <a href={contacts.calendlyUrl} class="btn btn-ghost">{dict.contact.btnCall}</a>
      <a href={`mailto:${contacts.email}`} class="btn btn-ghost">{contacts.email}</a>
    </div>
  </div>
</section>
