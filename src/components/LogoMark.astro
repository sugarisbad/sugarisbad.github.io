---
// Знак «монолит» (export-1c/logo.svg, версия с жирными коннекторами — читается
// в мелких размерах). Цвет наследуется через currentColor.
interface Props {
  /** Размер стороны в px. */
  size?: number;
}
const { size = 20 } = Astro.props;
---

<svg
  class="brand-mark"
  width={size}
  height={size}
  viewBox="0 0 96 96"
  fill="currentColor"
  aria-hidden="true"
>
  <rect x="18" y="6" width="26" height="84"></rect>
  <rect x="44" y="21" width="34" height="5"></rect>
  <rect x="44" y="45" width="24" height="5"></rect>
  <rect x="44" y="69" width="34" height="5"></rect>
</svg>
