---
// Кейсы: hero + 3 кейса-строки «таблицей» (метрики справа) + CTA.
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { contacts } from '../data/site';
import { t, localeUrl, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}
const { locale = 'ru' } = Astro.props;
const dict = t(locale);
const base = import.meta.env.BASE_URL;
const p = (s: string) => localeUrl(locale, s, base);

// Метка источника для бота: src-cases / src-cases-en
const botLink = `${contacts.botUrl}?start=src-cases${locale === 'en' ? '-en' : ''}`;
---

<Base title={dict.casesPage.title} description={dict.casesPage.desc} locale={locale} path="cases/" bg="page" ogImage={`/og/cases${locale === 'en' ? '-en' : ''}.jpg`}>
  <Header locale={locale} path="cases/" active="cases" cta="contact" />

  <section class="hero-page">
    <div class="wrap">
      <span class="kicker fx">{dict.casesPage.kicker}</span>
      <h1 class="h1 fx-1" set:html={dict.casesPage.h1} />
      <p class="lead fx-2">{dict.casesPage.sub}</p>
    </div>
  </section>

  <section class="cases-wrap">
    <div class="wrap">
      <div class="case-list">
        {dict.casesPage.items.map((c) => (
          <article class="case">
            <div class="case-main">
              <div class="case-top">
                <span class="case-num">{c.num}</span>
                <span class="badge">{c.badge}</span>
              </div>
              <h2>{c.title}</h2>
              <p><b>{dict.casesPage.problemLabel} </b>{c.problem}</p>
              <p><b>{dict.casesPage.solutionLabel} </b>{c.solution}</p>
              <div class="tags">
                {c.stack.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            </div>
            <div class="case-side">
              {c.metrics.map((m) => (
                <div class="case-metric">
                  <b>{m.value}</b>
                  <span>{m.label}</span>
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-sec">
    <div class="wrap">
      <h2 set:html={dict.casesPage.ctaH2} />
      <p class="lead">{dict.casesPage.ctaText}</p>
      <div class="cta-row">
        <a href={botLink} class="btn btn-primary">{dict.casesPage.ctaBot}</a>
        <a href={contacts.calendlyUrl} class="btn btn-ghost">{dict.casesPage.ctaCall}</a>
        <a href={p('services/')} class="btn btn-ghost">{dict.casesPage.ctaServices}</a>
      </div>
    </div>
  </section>

  <Footer locale={locale} />
</Base>
