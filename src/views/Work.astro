---
// Процесс: 5 шагов-строк с бейджем результата, 3 принципа-карточки, CTA.
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { contacts } from '../data/site';
import { t, localeUrl, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}
const { locale = 'ru' } = Astro.props;
const dict = t(locale);
const base = import.meta.env.BASE_URL;
const p = (s: string) => localeUrl(locale, s, base);

// Метка источника для бота: src-work / src-work-en
const botLink = `${contacts.botUrl}?start=src-work${locale === 'en' ? '-en' : ''}`;

// FAQPage: те же 6 вопросов, что в видимом аккордеоне (llms.txt обещает FAQ здесь)
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: dict.workPage.faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
// В референсах порядок CTA различается: RU — бот главный, EN — Calendly главный.
const ctaButtons =
  locale === 'ru'
    ? [
        { href: botLink, label: dict.workPage.ctaBot, primary: true },
        { href: contacts.calendlyUrl, label: dict.workPage.ctaCall, primary: false },
        { href: p('services/'), label: dict.workPage.ctaCalc, primary: false },
      ]
    : [
        { href: contacts.calendlyUrl, label: dict.workPage.ctaCall, primary: true },
        { href: botLink, label: dict.workPage.ctaBot, primary: false },
        { href: p('services/'), label: dict.workPage.ctaCalc, primary: false },
      ];
---

<Base title={dict.workPage.title} description={dict.workPage.desc} locale={locale} path="work/" bg="page" ogImage={`/og/work${locale === 'en' ? '-en' : ''}.jpg`}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqLd)} />

  <Header locale={locale} path="work/" active="work" cta={locale === 'ru' ? 'contact' : 'call'} />

  <section class="hero-page">
    <div class="wrap">
      <span class="kicker fx">{dict.workPage.kicker}</span>
      <h1 class="h1 fx-1" set:html={dict.workPage.h1} />
      <p class="lead fx-2">{dict.workPage.sub}</p>
    </div>
  </section>

  <section class="steps-wrap">
    <div class="wrap">
      <div class="steps">
        {dict.workPage.steps.map((s) => (
          <div class="step">
            <span class="step-num">{s.num}</span>
            <h3>{s.title}</h3>
            <p>{s.text}</p>
            <span class="step-out">→ {s.output}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="principles-sec">
    <div class="wrap">
      <span class="kicker">{dict.workPage.principlesKicker}</span>
      <div class="tiles">
        {dict.workPage.principles.map((pr) => (
          <div class="principle">
            <div class="num">{pr.num}</div>
            <h3>{pr.title}</h3>
            <p>{pr.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="faq-sec">
    <div class="wrap">
      <div class="faq-head">
        <div>
          <span class="kicker">{dict.workPage.faqKicker}</span>
          <h2 class="h2" set:html={dict.workPage.faqH2} />
        </div>
        <span class="faq-hint">{dict.workPage.faqHint} <a href={botLink}>{dict.workPage.faqHintLink}</a></span>
      </div>
      <div class="faq-list">
        {dict.workPage.faq.map((f, i) => (
          <details class="faq-item" name="faq" open={i === 0}>
            <summary>
              <span class="num">/ 0{i + 1}</span>
              <span class="q">{f.q}</span>
              <span class="mark" aria-hidden="true"></span>
            </summary>
            <div class="a"><p>{f.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-sec">
    <div class="wrap">
      <h2 set:html={dict.workPage.ctaH2} />
      <p class="lead">{dict.workPage.ctaText}</p>
      <div class="cta-row">
        {ctaButtons.map((b) => (
          <a href={b.href} class={`btn ${b.primary ? 'btn-primary' : 'btn-ghost'}`}>{b.label}</a>
        ))}
      </div>
    </div>
  </section>

  <Footer locale={locale} />
</Base>
