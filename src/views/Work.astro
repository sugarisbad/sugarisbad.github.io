---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { t, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);

// FAQ-микроразметка: расширенный сниппет в выдаче Google и Яндекса.
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: dict.faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base title={dict.workPage.title} description={dict.workPage.desc} locale={locale} path="work/">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqLd)} />
  <Header locale={locale} path="work/" />

  <!-- HERO -->
  <section class="hero hero-compact">
    <div class="wrap">
      <span class="eyebrow">{dict.workPage.eyebrow}</span>
      <h1>{dict.workPage.h1}</h1>
      <p class="sub">{dict.workPage.sub}</p>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section-tight">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">{dict.workPage.processEyebrow}</span>
        <h2>{dict.workPage.processH2}</h2>
      </div>
      <div class="steps reveal">
        {dict.process.map((s) => (
          <div class="step"><h4>{s.title}</h4><p>{s.text}</p></div>
        ))}
      </div>
    </div>
  </section>

  <!-- GUARANTEES -->
  <section>
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">{dict.workPage.guaranteesEyebrow}</span>
        <h2>{dict.workPage.guaranteesH2}</h2>
        <p class="lead">{dict.workPage.guaranteesLead}</p>
      </div>
      <div class="steps reveal">
        {dict.guarantees.map((g) => (
          <div class="step guarantee">
            <div class="ico">{g.icon}</div>
            <h4>{g.title}</h4>
            <p>{g.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMPARE -->
  <section>
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">{dict.workPage.compareEyebrow}</span>
        <h2>{dict.workPage.compareH2}</h2>
        <p class="lead">{dict.workPage.compareLead}</p>
      </div>
      <div class="compare-wrap reveal">
        <table class="compare">
          <thead>
            <tr>{dict.compare.columns.map((c, i) => <th class={i === 1 ? 'me' : ''}>{c}</th>)}</tr>
          </thead>
          <tbody>
            {dict.compare.rows.map((row) => (
              <tr>{row.map((cell, i) => i === 0 ? <th scope="row">{cell}</th> : <td class={i === 1 ? 'me' : ''}>{cell}</td>)}</tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section>
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">{dict.workPage.faqEyebrow}</span>
        <h2>{dict.workPage.faqH2}</h2>
      </div>
      <div class="faq reveal">
        {dict.faq.map((f) => (
          <details class="faq-item">
            <summary><span>{f.q}</span><b class="faq-plus" aria-hidden="true">+</b></summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Contact locale={locale} source="src-work" />
  <Footer locale={locale} />
</Base>
