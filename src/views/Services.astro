---
// Услуги и цены: hero + калькулятор заказа (полный прайс из pricing.ts).
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Calculator from '../components/Calculator.astro';
import Footer from '../components/Footer.astro';
import { PRICING } from '../data/pricing';
import { t, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}
const { locale = 'ru' } = Astro.props;
const dict = t(locale);

// Каталог услуг с ценами: расширенные сниппеты с ценой в Яндексе и Google.
const offersLd = {
  '@context': 'https://schema.org',
  '@type': 'OfferCatalog',
  name: dict.servicesPage.title,
  itemListElement: PRICING.flatMap((g) =>
    g.items.map((it) => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: locale === 'ru' ? it.name_ru : it.name_en },
      price: it.rub,
      priceCurrency: 'RUB',
    }))
  ),
};
---

<Base title={dict.servicesPage.title} description={dict.servicesPage.desc} locale={locale} path="services/" bg="services">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(offersLd)} />

  <Header locale={locale} path="services/" active="services" cta="call" />

  <section class="hero-services">
    <div class="wrap">
      <span class="kicker fx">{dict.servicesPage.kicker}</span>
      <h1 class="h1 fx-1" set:html={dict.servicesPage.h1} />
      <p class="lead fx-2">{dict.servicesPage.sub}</p>
      {locale === 'en' && (
        <p class="rate-note fx-2" id="rate-note" data-text={dict.servicesPage.rateNote}>{dict.servicesPage.rateNote}</p>
      )}
    </div>
  </section>

  <Calculator locale={locale} />

  <Footer locale={locale} flush />
</Base>
