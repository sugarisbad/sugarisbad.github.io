---
// Главная: hero со статус-панелью, статистика, услуги-строки, кейсы-превью, контакт.
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Contact from '../components/Contact.astro';
import { t, localeUrl, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}
const { locale = 'ru' } = Astro.props;
const dict = t(locale);
const base = import.meta.env.BASE_URL;
const p = (s: string) => localeUrl(locale, s, base);
---

<Base title={dict.home.title} description={dict.home.desc} locale={locale} path="" bg="home">
  <Header locale={locale} path="" cta="contact" />

  <section class="hero-home">
    <div class="wrap hero-grid">
      <div>
        <span class="kicker fx">{dict.home.kicker}</span>
        <h1 class="fx-1" set:html={dict.home.h1} />
        <p class="lead fx-2">{dict.home.sub}</p>
        <div class="cta-row fx-3">
          <a href="#contact" class="btn btn-primary">{dict.home.ctaDiscuss}</a>
          <a href={p('cases/')} class="btn btn-ghost">{dict.home.ctaCases}</a>
        </div>
      </div>
      <div class="status-panel fx-4">
        <div class="status-head">{dict.home.status.head} <span class="status-dot"></span></div>
        {dict.home.status.rows.map((r) => (
          <div class="status-row"><span>{r.name}</span><b class={r.tone}>{r.value}</b></div>
        ))}
        {dict.home.status.foot.map((r, i) => (
          <div class={`status-row${i === 0 ? ' status-sep' : ''}`}><span>{r.name}</span><b class="text">{r.value}</b></div>
        ))}
      </div>
    </div>
    <div class="wrap">
      <div class="stats fx-5">
        {dict.home.stats.map((s) => (
          <div class="stat">
            <b class={s.accent ? 'accent' : undefined}>{s.value}</b>
            <span>{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="svc-head">
        <div>
          <span class="kicker">{dict.home.servicesKicker}</span>
          <h2 class="h2" set:html={dict.home.servicesH2} />
        </div>
        <p class="lead">{dict.home.servicesLead}</p>
      </div>
      <div class="svc-rows">
        {dict.home.services.map((s) => (
          <div class="svc-row">
            <span class="num">{s.num}</span>
            <h3>{s.title}</h3>
            <p>{s.text}</p>
            <span class="arrow">→</span>
          </div>
        ))}
      </div>
      <div class="svc-btns">
        <a href={p('services/')} class="btn btn-primary">{dict.home.btnPrices}</a>
        <a href={p('work/')} class="btn btn-ghost">{dict.home.btnWork}</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="sec-head-row">
        <div>
          <span class="kicker">{dict.home.casesKicker}</span>
          <h2 class="h2" set:html={dict.home.casesH2} />
        </div>
        <a href={p('cases/')} class="link-more">{dict.home.casesAll}</a>
      </div>
      <div class="tiles">
        {dict.home.casesPreview.map((c) => (
          <div class="tile">
            <b>{c.value}</b>
            <h3>{c.title}</h3>
            <p>{c.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Contact locale={locale} source="src-home" />

  <Footer locale={locale} />
</Base>
