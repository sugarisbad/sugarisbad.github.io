---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { t, localeUrl, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const dict = t(locale);
const base = import.meta.env.BASE_URL;
const p = (s: string) => localeUrl(locale, s, base);
---

<Base title={dict.home.title} description={dict.home.desc} locale={locale} path="">
  <Header locale={locale} path="" />

  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <div class="badge"><span class="live"></span> {dict.home.badge}</div>
      <h1 set:html={dict.home.h1} />
      <p class="sub">{dict.home.sub}</p>
      <div class="hero-cta">
        <a href="#contact" class="btn btn-primary">{dict.home.ctaDiscuss}</a>
        <a href={p('cases/')} class="btn btn-ghost">{dict.home.ctaCases}</a>
      </div>
      <div class="stats">
        {dict.heroStats.map((s) => (
          <div class="stat"><b class="grad-text">{s.value}</b><span>{s.label}</span></div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">{dict.home.servicesEyebrow}</span>
        <h2 set:html={dict.home.servicesH2} />
        <p class="lead">{dict.home.servicesLead}</p>
      </div>
      <div class="grid">
        {dict.services.map((s) => (
          <article class="card reveal">
            <div class="gborder-fx"></div>
            <div class="ico">{s.icon}</div>
            <h3>{s.title}</h3>
            <p>{s.text}</p>
            <ul class="tags">{s.tags.map((tag) => <li>{tag}</li>)}</ul>
          </article>
        ))}
      </div>
      <div class="hero-cta" style="margin-top:40px">
        <a href={p('services/')} class="btn btn-ghost">{dict.home.btnPrices}</a>
        <a href={p('work/')} class="btn btn-ghost">{dict.home.btnWork}</a>
      </div>
    </div>
  </section>

  <Contact locale={locale} />
  <Footer locale={locale} />
</Base>
