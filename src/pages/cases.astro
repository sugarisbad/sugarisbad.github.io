---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { contacts, cases, stack } from '../data/site';

const desc =
  'Кейсы: платформа аренды видеокарт, самовосстанавливающийся сайт, мониторинг оборудования 24/7, сети серверов с балансировкой. Реальные системы, собранные целиком одним инженером.';
---

<Base title={`Кейсы — ${contacts.name} (${contacts.username}), DevOps-инженер`} description={desc}>
  <Header />

  <!-- HERO -->
  <section class="hero hero-compact">
    <div class="wrap">
      <span class="eyebrow">// реальные проекты</span>
      <h1>Кейсы</h1>
      <p class="sub">
        Системы, которые я спроектировал и собрал целиком. Описал простыми словами —
        техническими деталями с удовольствием поделюсь на созвоне.
      </p>
    </div>
  </section>

  <!-- CASES -->
  <section class="section-tight">
    <div class="wrap">
      <div class="cases-grid reveal">
        {cases.map((c) => (
          <article class="card case-card">
            <div class="gborder-fx"></div>
            <div class="case-card-top">
              <div class="ico">{c.icon}</div>
              <div class="case-stat"><b class="grad-text">{c.stat.value}</b><span>{c.stat.label}</span></div>
            </div>
            <h3>{c.title}</h3>
            <p>{c.text}</p>
            <ul class="tags">{c.tags.map((t) => <li>{t}</li>)}</ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- STACK (marquee) -->
  <section class="stack-section">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">// инструменты</span>
        <h2>Технологический стек</h2>
        <p class="lead">
          То, чем я работаю каждый день — от системного администрирования до интеграции нейросетей.
        </p>
      </div>
    </div>
    <div class="marquee reveal" aria-label="Технологии">
      <div class="marquee-track">
        {stack.map((t) => <span class="chip"><i></i>{t}</span>)}
        {stack.map((t) => <span class="chip" aria-hidden="true"><i></i>{t}</span>)}
      </div>
    </div>
  </section>

  <Contact
    title="Хотите такую же систему?"
    text="Расскажите, что нужно вашему проекту, — предложу решение и оценку в течение дня."
  />
  <Footer />
</Base>
