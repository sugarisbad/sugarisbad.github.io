---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { contacts, plans, priceGroups } from '../data/site';

const desc =
  'Услуги и цены DevOps-инженера: настройка VPS от 7 000 ₽, мониторинг от 15 000 ₽, self-hosted ИИ от 20 000 ₽, системы под ключ. Смета фиксируется письменно, работа по предоплате.';
---

<Base title={`Услуги и цены — ${contacts.name} (${contacts.username}), DevOps-инженер`} description={desc}>
  <Header />

  <!-- HERO -->
  <section class="hero hero-compact">
    <div class="wrap">
      <div class="badge"><span class="live"></span> Смета фиксируется письменно · работа по предоплате</div>
      <h1>Услуги и <span class="grad-text">цены</span></h1>
      <p class="sub">
        Типовые пакеты и полный прайс. Все суммы «от …» — стартовые: точную смету назову
        после короткого созвона, и в процессе она не вырастет. Работаю по предоплате —
        обычно 50% до старта, остальное после результата.
      </p>
    </div>
  </section>

  <!-- PLANS -->
  <section class="section-tight">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">// пакеты</span>
        <h2>С чего обычно начинают</h2>
      </div>
      <div class="price-grid reveal">
        {plans.map((p) => (
          <div class={`price${p.featured ? ' featured' : ''}`}>
            <h3>{p.title}</h3>
            <p class="desc">{p.desc}</p>
            <div class="amount">{p.price}</div>
            <span class="meta">{p.meta}</span>
            <ul>{p.features.map((f) => <li>{f}</li>)}</ul>
            <a href="#contact" class={`btn ${p.featured ? 'btn-primary' : 'btn-ghost'}`}>{p.cta}</a>
          </div>
        ))}
      </div>
      <p class="price-note">
        <b>Абонентское администрирование</b> — от 10 000 ₽/мес: мониторинг, обновления,
        реакция на инциденты, мелкие правки. &nbsp;·&nbsp; Разовая консультация — 4 000 ₽/час.
      </p>
    </div>
  </section>

  <!-- PRICE LIST -->
  <section class="plist-section">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">// полный прайс</span>
        <h2>Типовые задачи</h2>
      </div>
      {priceGroups.map((g) => (
        <div class="pgroup reveal">
          <div class="pgroup-head">
            <span class="pgroup-ico">{g.icon}</span>
            <h2>{g.title}</h2>
          </div>
          <div class="plist">
            {g.items.map((item) => (
              <div class="pitem">
                <div class="pitem-info">
                  <h3>{item.name}</h3>
                  <p>{item.desc}</p>
                </div>
                <div class="pitem-meta">
                  <b class="grad-text">{item.price}</b>
                  <span class="mono">{item.time}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
      <p class="price-note">
        Часовая ставка — <b>4 000 ₽/час</b> (~$45). Комбинация нескольких услуг — дешевле,
        чем по отдельности: объединяю работы и не беру дважды за одно и то же.
        Работа начинается после предоплаты — на небольших задачах 50/50.
      </p>
    </div>
  </section>

  <Contact
    title="Не нашли свою задачу?"
    text="Прайс покрывает типовые работы, но большинство проектов — комбинация из них. Опишите задачу как умеете — я переведу её в смету с ценой и сроком в течение дня."
  />
  <Footer />
</Base>
