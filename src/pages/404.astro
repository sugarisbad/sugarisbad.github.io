---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { t } from '../i18n';

const ru = t('ru');
const en = t('en');
---

<Base title={`404 — ${ru.notFound.title}`} description={ru.notFound.text} noindex>
  <Header locale="ru" path="" />

  <section class="hero hero-compact">
    <div class="wrap">
      <span class="eyebrow">// 404</span>
      <h1>{ru.notFound.title}</h1>
      <p class="sub">{ru.notFound.text}<br />{en.notFound.text}</p>
      <div class="hero-cta">
        <a href="/" class="btn btn-primary">{ru.notFound.btnHome}</a>
        <a href="/en/" class="btn btn-ghost">{en.notFound.btnHome}</a>
      </div>
    </div>
  </section>

  <Footer locale="ru" />
</Base>
