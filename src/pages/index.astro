---
import Base from '../layouts/Base.astro';
import {
  contacts, heroStats, services, cases,
  stack, plans, process, guarantees, compare, faq,
} from '../data/site';

const base = import.meta.env.BASE_URL;
const mailto = `mailto:${contacts.email}?subject=${encodeURIComponent('Проект по DevOps')}`;
const desc =
  'DevOps-инженер: настройка и защита VPS, Docker, CI/CD, мониторинг и отказоустойчивость. Self-hosted ИИ (Ollama) и Telegram-боты. Проекты под ключ и абонентское администрирование.';
---

<Base title={`${contacts.name} (${contacts.username}) — DevOps-инженер: серверы, CI/CD, автоматизация`} description={desc}>
  <!-- NAV -->
  <header>
    <div class="wrap nav">
      <div class="brand"><span class="dot"></span> {contacts.name} <span class="brand-user mono">// {contacts.username}</span></div>
      <nav class="nav-links" id="nav">
        <a href="#services">Услуги</a>
        <a href="#cases">Кейсы</a>
        <a href="#pricing">Цены</a>
        <a href={`${base}services/`}>Прайс</a>
        <a href="#faq">FAQ</a>
        <a href="#contact" class="nav-cta">Связаться</a>
      </nav>
      <button class="burger" id="burger" aria-label="Меню">☰</button>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <div class="badge"><span class="live"></span> Принимаю проекты · ответ в течение дня</div>
      <h1><span class="grad-text">DevOps</span>-инженер<br />для вашей инфраструктуры</h1>
      <p class="sub">
        Серверы, Docker, CI/CD, мониторинг и отказоустойчивость. Вы получаете систему,
        которая сама следит за собой и чинит себя, — а не ещё одного подрядчика,
        которому надо писать по каждому поводу.
      </p>
      <div class="hero-cta">
        <a href="#contact" class="btn btn-primary">Обсудить задачу →</a>
        <a href="#cases" class="btn btn-ghost">Смотреть кейсы</a>
      </div>
      <div class="stats">
        {heroStats.map((s) => (
          <div class="stat"><b class="grad-text">{s.value}</b><span>{s.label}</span></div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">// что я делаю</span>
        <h2>DevOps как основа,<br />ИИ как усиление</h2>
        <p class="lead">
          Не «настрою хостинг по инструкции», а проектирую и собираю инфраструктуру целиком:
          серверы, контейнеры, деплой, мониторинг — как единую систему.
          Типовые задачи с ценами — <a href={`${base}services/`} class="lead-link">в прайсе</a>.
        </p>
      </div>
      <div class="grid">
        {services.map((s) => (
          <article class="card reveal">
            <div class="gborder-fx"></div>
            <div class="ico">{s.icon}</div>
            <h3>{s.title}</h3>
            <p>{s.text}</p>
            <ul class="tags">{s.tags.map((t) => <li>{t}</li>)}</ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CASES -->
  <section id="cases">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">// реальные проекты</span>
        <h2>Кейсы</h2>
        <p class="lead">
          Реальные системы, которые я спроектировал и собрал целиком. Описал простыми
          словами — техническими деталями с удовольствием поделюсь на созвоне.
        </p>
      </div>
      <div class="cases-grid reveal">
        {cases.map((c) => (
          <article class="card case-card">
            <div class="gborder-fx"></div>
            <div class="case-card-top">
              <div class="ico">{c.icon}</div>
              <div class="case-stat"><b class="grad-text">{c.stat.value}</b><span>{c.stat.label}</span></div>
            </div>
            <h3>{c.title}</h3>
            <p>{c.text}</p>
            <ul class="tags">{c.tags.map((t) => <li>{t}</li>)}</ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- GUARANTEES -->
  <section id="guarantees">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">// почему со мной спокойно</span>
        <h2>Гарантии, а не обещания</h2>
        <p class="lead">
          Главные страхи заказа у фрилансера — «пропадёт», «подорожает», «заберёт доступы».
          Закрываю их до старта, письменно.
        </p>
      </div>
      <div class="steps reveal">
        {guarantees.map((g) => (
          <div class="step guarantee">
            <div class="ico">{g.icon}</div>
            <h4>{g.title}</h4>
            <p>{g.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STACK (marquee) -->
  <section id="stack" class="stack-section">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">// инструменты</span>
        <h2>Технологический стек</h2>
        <p class="lead">
          То, чем я работаю каждый день — от системного администрирования до интеграции нейросетей.
        </p>
      </div>
    </div>
    <div class="marquee reveal" aria-label="Технологии">
      <div class="marquee-track">
        {stack.map((t) => <span class="chip"><i></i>{t}</span>)}
        {stack.map((t) => <span class="chip" aria-hidden="true"><i></i>{t}</span>)}
      </div>
    </div>
  </section>

  <!-- COMPARE -->
  <section id="compare">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">// форматы работы</span>
        <h2>Почему инженер напрямую — выгоднее</h2>
        <p class="lead">
          Те же задачи можно отдать агентству или нанять админа в штат. Вот честное сравнение.
        </p>
      </div>
      <div class="compare-wrap reveal">
        <table class="compare">
          <thead>
            <tr>{compare.columns.map((c, i) => <th class={i === 1 ? 'me' : ''}>{c}</th>)}</tr>
          </thead>
          <tbody>
            {compare.rows.map((row) => (
              <tr>{row.map((cell, i) => i === 0 ? <th scope="row">{cell}</th> : <td class={i === 1 ? 'me' : ''}>{cell}</td>)}</tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">// стоимость</span>
        <h2>Прозрачные цены</h2>
        <p class="lead">
          Ставка — от 4 000 ₽/час (~$45). Ниже — типовые пакеты. Точная смета после
          короткого созвона: фиксирую объём и цену до старта, без сюрпризов.
          Работаю по предоплате — обычно 50% до старта, остальное после демонстрации результата.
        </p>
      </div>
      <div class="price-grid reveal">
        {plans.map((p) => (
          <div class={`price${p.featured ? ' featured' : ''}`}>
            <h3>{p.title}</h3>
            <p class="desc">{p.desc}</p>
            <div class="amount">{p.price}</div>
            <span class="meta">{p.meta}</span>
            <ul>{p.features.map((f) => <li>{f}</li>)}</ul>
            <a href="#contact" class={`btn ${p.featured ? 'btn-primary' : 'btn-ghost'}`}>{p.cta}</a>
          </div>
        ))}
      </div>
      <p class="price-note">
        <b>Абонентское администрирование</b> — от 10 000 ₽/мес: мониторинг, обновления,
        реакция на инциденты, мелкие правки. &nbsp;·&nbsp; Разовая консультация — 4 000 ₽/час.
      </p>
      <div class="hero-cta" style="margin-top:26px">
        <a href={`${base}services/`} class="btn btn-ghost">Полный прайс типовых услуг →</a>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section id="process">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">// как мы работаем</span>
        <h2>Процесс без сюрпризов</h2>
      </div>
      <div class="steps reveal">
        {process.map((s) => (
          <div class="step"><h4>{s.title}</h4><p>{s.text}</p></div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">// вопросы</span>
        <h2>Частые вопросы</h2>
      </div>
      <div class="faq reveal">
        {faq.map((f) => (
          <details class="faq-item">
            <summary><span>{f.q}</span><b class="faq-plus" aria-hidden="true">+</b></summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact">
    <div class="wrap">
      <div class="cta-band reveal">
        <h2>Обсудим ваш проект?</h2>
        <p>
          Опишите задачу в двух словах — вернусь с решением и оценкой в течение дня.
          Первичная консультация ни к чему не обязывает.
        </p>
        <div class="hero-cta">
          {contacts.botUrl && <a href={contacts.botUrl} class="btn btn-primary">🤖 Оставить заявку в боте</a>}
          <a href={contacts.telegramUrl} class={`btn ${contacts.botUrl ? 'btn-ghost' : 'btn-primary'}`}>✈ Telegram · @{contacts.telegram}</a>
          <a href={contacts.phoneUrl} class="btn btn-ghost">📞 {contacts.phone}</a>
          <a href={mailto} class="btn btn-ghost">✉ Написать на почту</a>
          <a href={contacts.githubUrl} class="btn btn-ghost" rel="noopener">⌥ GitHub · {contacts.github}</a>
        </div>
      </div>
    </div>
  </section>

  <footer>
    <div class="wrap foot">
      <div class="brand"><span class="dot"></span> {contacts.name} <span class="brand-user mono">// {contacts.username}</span></div>
      <div class="foot-links">
        <a href={contacts.phoneUrl}>{contacts.phone}</a>
        <a href={mailto}>{contacts.email}</a>
        <a href={contacts.telegramUrl}>@{contacts.telegram}</a>
        <a href={contacts.githubUrl} rel="noopener">github.com/{contacts.github}</a>
        <a href={`${base}services/`}>Прайс</a>
        <a href="#pricing">Цены</a>
      </div>
      <div style="font-size:.86rem">DevOps · автоматизация · self-hosted ИИ · <span id="year"></span></div>
    </div>
  </footer>
</Base>
