---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { contacts, heroStats, services } from '../data/site';

const base = import.meta.env.BASE_URL;
const desc =
  'DevOps-инженер: настройка и защита VPS, Docker, CI/CD, мониторинг и отказоустойчивость. Self-hosted ИИ (Ollama) и Telegram-боты. Проекты под ключ и абонентское администрирование.';
---

<Base title={`${contacts.name} (${contacts.username}) — DevOps-инженер: серверы, CI/CD, автоматизация`} description={desc}>
  <Header />

  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <div class="badge"><span class="live"></span> Принимаю проекты · ответ в течение дня</div>
      <h1><span class="grad-text">DevOps</span>-инженер<br />для вашей инфраструктуры</h1>
      <p class="sub">
        Серверы, Docker, CI/CD, мониторинг и отказоустойчивость. Вы получаете систему,
        которая сама следит за собой и чинит себя, — а не ещё одного подрядчика,
        которому надо писать по каждому поводу.
      </p>
      <div class="hero-cta">
        <a href="#contact" class="btn btn-primary">Обсудить задачу →</a>
        <a href={`${base}cases/`} class="btn btn-ghost">Смотреть кейсы</a>
      </div>
      <div class="stats">
        {heroStats.map((s) => (
          <div class="stat"><b class="grad-text">{s.value}</b><span>{s.label}</span></div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services">
    <div class="wrap">
      <div class="section-head reveal">
        <span class="eyebrow">// что я делаю</span>
        <h2>DevOps как основа,<br />ИИ как усиление</h2>
        <p class="lead">
          Проектирую и собираю инфраструктуру целиком: серверы, контейнеры, деплой,
          мониторинг — как единую систему.
        </p>
      </div>
      <div class="grid">
        {services.map((s) => (
          <article class="card reveal">
            <div class="gborder-fx"></div>
            <div class="ico">{s.icon}</div>
            <h3>{s.title}</h3>
            <p>{s.text}</p>
            <ul class="tags">{s.tags.map((t) => <li>{t}</li>)}</ul>
          </article>
        ))}
      </div>
      <div class="hero-cta" style="margin-top:40px">
        <a href={`${base}services/`} class="btn btn-ghost">Цены и полный прайс →</a>
        <a href={`${base}work/`} class="btn btn-ghost">Как я работаю →</a>
      </div>
    </div>
  </section>

  <Contact />
  <Footer />
</Base>
