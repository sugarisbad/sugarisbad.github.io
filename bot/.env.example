# Токен бота из @BotFather
BOT_TOKEN=1234567890:AAAA...

# Ваш chat id — куда бот шлёт заявки (узнать: @userinfobot).
ADMIN_CHAT_ID=123456789

# Необязательно: локальная Ollama — авто-разбор заявок и черновики ответов
# на вопросы клиентов. Если не задано — бот работает без LLM.
#OLLAMA_URL=http://127.0.0.1:11434
#OLLAMA_MODEL=gemma2
# Таймаут генерации в секундах (на CPU может быть медленно; по умолчанию 300).
#OLLAMA_TIMEOUT=300

# Необязательно: путь к SQLite-базе заявок (по умолчанию leads.db рядом с ботом).
#LEADS_DB=leads.db
